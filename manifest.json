{
  "bundle": "tool_foundry_health_security_recovery_v1",
  "target_repo": "Pyth-agoras/tool-foundry-backend",
  "purpose": "Implement real auth and mutation enforcement, then expose truthful /health flags.",
  "approved_paths": [
    "src/server.js",
    "src/executable_tool_router.js"
  ],
  "required_env": [
    "API_KEY"
  ],
  "mutation_requirements": [
    "approved === true",
    "approval_confirmed === true",
    "install_payload_validated === true",
    "validation_result.validation_status === passed",
    "validation_result.can_install === true"
  ],
  "rollback": "Exact prior file copies in .recovery-backup-foundation-security",
  "secrets_included": false
}